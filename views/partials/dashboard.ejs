<main class="min-h-screen bg-gray-50 px-4 py-6 text-gray-800">
  <div class="mx-auto flex max-w-6xl flex-col gap-6">
    
    <!-- Folders -->
    <section class="rounded-2xl bg-white p-4 shadow-sm">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-3">
          <span class="material-icons text-gray-800">folder</span>
          <h2 class="text-lg font-semibold text-gray-800">Folders</h2>
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <nav class="grow flex scroll gap-2">
            <a
              href="#"
              id="all"
              class="rounded-xl bg-yellow-200 px-4 py-2 font-medium text-gray-800 transition hover:bg-yellow-300"
            >
              All
            </a>
            <a
              href="#"
              class="rounded-xl border border-gray-200 px-4 py-2 font-medium text-gray-800 transition hover:bg-gray-100"
            >
              Work
            </a>
            <a
              href="#"
              class="rounded-xl border border-gray-200 px-4 py-2 font-medium text-gray-800 transition hover:bg-gray-100"
            >
              Personal
            </a>
          </nav>
          <button
            class="inline-flex items-center justify-center rounded-xl bg-yellow-200 px-4 py-2 font-medium text-gray-800 transition hover:bg-gray-700 ml-auto"
          >
            <span class="text-xl leading-none">+</span>
          </button>
        </div>

      </div>
    </section>

    <!-- Notes -->
    <section>
      <div class="mb-4 flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-800">Notes</h1>
        <span class="text-sm text-gray-500"><span id=notes-counter"><%= notes.length %></span> notes</span>
      </div>


      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3" id="notes-container">
        
        <% for (const note of notes) { %>

        <article class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm transition hover:shadow-md">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="text-lg font-semibold text-gray-800"><%= note.title %></h3>
              <p class="mt-1 text-sm text-gray-500"><%= note.date %></p>
            </div>

            <a href="/editor/<%= note.id %>" class="rounded-xl bg-yellow-200 p-2 text-gray-800 transition hover:bg-yellow-300">
              <span class="material-icons text-base">edit</span>
            </a>
          </div>
        </article>

	<% } %>

      </div>
    </section>
  </div>
</main>
<a href="/editor" class="fixed w-12 h-12 bg-yellow-200 text-gray-800 rounded-lg grid content-center text-center font-bold text-2xl bottom-10 right-10 shadow-lg transition hover:bg-gray-700">+</a>
