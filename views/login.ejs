<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/common-head.ejs") %>

    <title>NotEd - Log In</title>
  </head>
  <body class="text-gray-800 min-h-screen flex flex-col bg-gray-50">
    <%- include("partials/header.ejs") %>

    <main class="flex flex-1 items-center justify-center px-4 py-10">
      <div
        class="w-full max-w-md rounded-2xl bg-white p-8 shadow-lg border border-gray-200"
      >
        <form id="login-form" class="flex flex-col gap-4">
          <h2 class="text-center text-3xl font-bold text-gray-900">Log In</h2>

          <p id="error-msg" class="hidden rounded-xl bg-red-100 px-4 py-2 text-sm text-red-700 text-center"></p>

          <div class="flex flex-col gap-2">
            <label for="name-input" class="text-sm font-medium text-gray-700">
              Username
            </label>
            <input
              class="w-full rounded-xl border border-gray-300 px-4 py-3 outline-none transition focus:border-yellow-200 focus:ring-2 focus:ring-yellow-200"
              type="text"
              name="user"
              placeholder="John Doe..."
              id="name-input"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label
              for="password-input"
              class="text-sm font-medium text-gray-700"
            >
              Password
            </label>
            <input
              class="w-full rounded-xl border border-gray-300 px-4 py-3 outline-none transition focus:border-yellow-200 focus:ring-2 focus:ring-yellow-200"
              type="password"
              name="password"
              placeholder="12345..."
              id="password-input"
            />
          </div>

          <input
            class="mt-2 cursor-pointer rounded-xl bg-yellow-200 py-3 font-semibold text-gray-800 transition hover:bg-yellow-200 active:scale-[0.99] disabled:opacity-50 disabled:cursor-not-allowed"
            type="submit"
            id="submit-input"
            value="Send"
          />
        </form>
      </div>
    </main>

    <p class="mb-8 text-center text-sm text-gray-600">
      Don't you have an account? Create one for free:
      <a href="/register" class="font-medium text-yellow-300 hover:underline"
        >Sign Up</a
      >
    </p>

    <%- include("partials/footer.ejs") %>

    <script src="/script/login.js"></script>
  </body>
</html>
