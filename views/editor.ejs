<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/common-head.ejs") %>

    <title>NotEd - Editor</title>
  </head>

  <body class="min-h-screen bg-white text-gray-800 antialiased">
    <%- include("partials/header.ejs") %>
    <main class="mx-auto max-w-5xl px-4 py-6 sm:px-6 lg:px-8">
      <section class="rounded-4xl border border-gray-200 bg-white shadow-sm">
        <div class="border-b border-gray-200 p-4 sm:p-5">
          <div
            class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
          >
            <div class="space-y-2">
              <input
                type="text"
                value="<%= note.date %>"
                class="w-full bg-transparent text-2xl font-semibold tracking-tight outline-none placeholder:text-gray-400"
              />
              <p class="text-gray-400"><%= note.date %></p>
            </div>

            <div class="flex flex-wrap items-center gap-2">
              <button
                class="rounded-xl border border-gray-200 bg-white p-2 transition hover:bg-gray-50 grid content-center"
              >
                <span class="material-icons text-[20px]">format_bold</span>
              </button>
              <button
                class="rounded-xl border border-gray-200 bg-white p-2 transition hover:bg-gray-50 grid content-center"
              >
                <span class="material-icons text-[20px]">format_italic</span>
              </button>
              <button
                class="rounded-xl border border-gray-200 bg-white p-2 transition hover:bg-gray-50 grid content-center"
              >
                <span class="material-icons text-[20px]"
                  >format_list_bulleted</span
                >
              </button>
              <button
                class="rounded-xl border border-gray-200 bg-white p-2 transition hover:bg-gray-50 grid content-center"
              >
                <span class="material-icons text-[20px]">link</span>
              </button>
              <button
                class="rounded-xl border border-gray-200 bg-white p-2 transition hover:bg-gray-50 grid content-center"
              >
                <span class="material-icons text-[20px]">image</span>
              </button>

              <button
                class="inline-flex items-center gap-2 rounded-xl bg-yellow-200 px-4 py-2 text-sm font-medium text-gray-800 shadow-sm transition hover:opacity-90 ml-auto"
              >
                <span class="material-icons text-[18px]">save</span>
                Save
              </button>
            </div>
          </div>
        </div>

        <div class="p-4 sm:p-5">
          <div
            class="rounded-3xl border border-gray-200 bg-white p-4 shadow-sm"
          >
            <div class="mb-3 flex items-center gap-2 text-sm text-gray-500">
              <span class="material-icons text-[18px] text-yellow-500"
                >edit_note</span
              >
              Writing area
            </div>

            <textarea
              class="min-h-[520px] w-full resize-none rounded-2xl border border-gray-200 bg-white p-4 text-base leading-7 outline-none placeholder:text-gray-400 focus:border-yellow-300"
              placeholder="Start writing..."
            >
<%= note.content %></textarea
            >
          </div>
        </div>
      </section>
    </main>

    <%- include("partials/footer.ejs") %>
  </body>
</html>
